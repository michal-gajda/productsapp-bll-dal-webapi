{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Validation": {
    "Product": {
      "NameMinLength": 2,
      "NameMaxLength": 200,
      "DescriptionMaxLength": 1000,
      "PriceMin": 0.01,
      "PriceMax": 999999.99,
      "CategoryMinLength": 2,
      "CategoryMaxLength": 100
    }
  }
}
